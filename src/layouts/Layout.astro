---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  html {
    @apply bg-primary scroll-smooth;
  }
  * {
    @apply text-text font-sans;
  }
  body {
    @apply flex items-center justify-center;
  }
  main {
    @apply relative flex flex-col w-2/5 m-auto;
  }
  section {
    @apply min-h-screen flex flex-col justify-center gap-10;
  }
  h2 {
    @apply text-5xl py-2 mb-10 font-semibold bg-clip-text bg-[length:400%_400%] text-transparent bg-gradient-to-r from-pink-400 to-red-600 animate-[shine_4s_infinite];
  }
  .menu {
    @apply mb-6;
  }

  @keyframes shine {
    0% {
      background-position: 14% 0%;
    }
    50% {
      background-position: 87% 100%;
    }
    100% {
      background-position: 14% 0%;
    }
  }
</style>
