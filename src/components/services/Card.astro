---
interface Props {
  desc: string;
}

const { desc } = Astro.props;
---

<div
  class="flex items-center px-2 text-center aspect-square bg-secondary rounded-sm hover:bg-gradient-to-br hover:from-pink-600 hover:to-red-600 hover:scale-105 transition-all"
>
  <h3 class="text-lg font-semibold">
    {desc}
  </h3>
</div>

<style>
  @keyframes bg-services {
    0% {
      background-position: 14% 0%;
    }
    50% {
      background-position: 87% 100%;
    }
    100% {
      background-position: 14% 0%;
    }
  }
</style>
