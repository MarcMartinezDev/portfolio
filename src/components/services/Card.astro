---
interface Props {
  desc: string;
  dark?: boolean;
}

const { desc, dark } = Astro.props;
---

<div class="flex items-center">
  <div class="w-1/3">
    <img src="/icons/astro.png" alt="" width={100} height={100}>
  </div>
  <div class="w-2/3">
    <h3 class="text-lg font-semibold">
      {desc}
    </h3>
  </div>
</div>

<style></style>
